@model IEnumerable<VgcCollege.Models.Assignment>

@{
    ViewData["Title"] = "Manage Assignments";
}

<h2>Assignments</h2>
<p><a class="btn btn-primary" asp-action="Create">Create new assignment</a></p>
<table class="table">
    <thead><tr><th>Title</th><th>Course</th><th>Due</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach(var a in Model)
    {
        <tr>
            <td>@a.Title</td>
            <td>@a.Course?.Name</td>
            <td>@a.DueDate.ToShortDateString()</td>
            <td>
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@a.Id">Edit</a>
                <form asp-action="Delete" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@a.Id" />
                    <button type="submit" class="btn btn-link">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
