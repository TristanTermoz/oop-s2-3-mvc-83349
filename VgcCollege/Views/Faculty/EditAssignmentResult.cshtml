@model VgcCollege.Models.AssignmentResult

@{
    ViewData["Title"] = "Edit Assignment Result";
}

<h2>Edit Assignment Result</h2>
<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div>
        <label>Assignment name (edit)</label>
        <input name="Assignment.Title" value="@(Model.Assignment?.Title ?? "")" />
    </div>
    <div>
        <label asp-for="Score"></label>
        <input asp-for="Score" />
    </div>
    <div>
        <label asp-for="Feedback"></label>
        <textarea asp-for="Feedback"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
