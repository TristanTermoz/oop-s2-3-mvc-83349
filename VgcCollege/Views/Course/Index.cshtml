@model IEnumerable<VgcCollege.Models.Course>

@{
    ViewData["Title"] = "Manage Courses";
}

<h2>Courses</h2>
<p><a asp-action="Create">Create new course</a></p>
<ul>
@foreach(var c in Model)
{
    <li>@c.Name - Branch: @c.Branch?.Name - Faculty: @c.Faculty?.Name - <a asp-action="Edit" asp-route-id="@c.Id">Edit</a>
        <form asp-action="Delete" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@c.Id" />
            <button type="submit" class="btn btn-link">Delete</button>
        </form>
    </li>
}
</ul>
