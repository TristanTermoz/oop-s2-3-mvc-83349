@model VgcCollege.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<h2>Create Course</h2>
<form method="post">
    @Html.AntiForgeryToken()
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
    </div>
    <div>
        <label asp-for="BranchId">Branch</label>
        <select asp-for="BranchId" asp-items='@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList((IEnumerable<VgcCollege.Models.Branch>)ViewData["Branches"], "Id", "Name"))'></select>
    </div>
    <div>
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" />
    </div>
    <div>
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" />
    </div>
    <button type="submit">Create</button>
</form>
