@model VgcCollege.Models.StudentCreateViewModel

@{
    ViewData["Title"] = "Create Student";
}

<h2>Create Student</h2>
<form asp-action="CreateStudent" asp-controller="UserAdmin" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-2">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Password"></label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Phone"></label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Address"></label>
        <input asp-for="Address" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="DateOfBirth"></label>
        <input asp-for="DateOfBirth" type="date" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="StudentNumber"></label>
        <input asp-for="StudentNumber" class="form-control" />
    </div>
    <div class="mb-2">
        <label>Courses</label>
        <select asp-for="SelectedCourseIds" asp-items='@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList((IEnumerable<VgcCollege.Models.Course>)ViewData["Courses"], "Id", "Name"))' multiple class="form-control"></select>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
